---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const speakers = await getCollection('speakers');
  return speakers.map((speaker) => ({ params: { id: speaker.id }, props: { speaker } }));
}

const { speaker } = Astro.props;
const { data } = speaker;

const videos = (await getCollection('videos')).filter((v) => v.data.speakerId?.id === speaker.id);

const description = data.bio ?? `${data.name}, speaker at Pune Tech Community.`;

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.name,
  jobTitle: data.title,
  description,
};
---

<Layout title={data.name} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />

  <div class="container-narrow">
    <a href="/speakers" class="back">&larr; Back to speakers</a>
    <div class="header">
      <div class="avatar-placeholder avatar" />
      <div>
        <h1 class="name">{data.name}</h1>
        {data.title && <div class="title">{data.title}</div>}
        <div class="social">
          {data.linkedin && <a href={data.linkedin} target="_blank" rel="noopener">LinkedIn</a>}
          {data.twitter && <a href={data.twitter} target="_blank" rel="noopener">X / Twitter</a>}
        </div>
      </div>
    </div>
    {data.bio && <p class="bio">{data.bio}</p>}

    {videos.length > 0 && (
      <>
        <h2 class="section-title" style="font-size:20px;">Past talks</h2>
        <div class="videos-grid">
          {videos.map((v) => (
            <a href="https://www.youtube.com/c/PuneTechCommunity" target="_blank" rel="noopener" class="video-row">
              <img src={`https://img.youtube.com/vi/${v.data.youtubeId}/hqdefault.jpg`} alt="" class="thumb" loading="lazy" />
              <div>
                <div class="video-title">{v.data.title}</div>
                <div class="video-duration">{v.data.duration}</div>
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</Layout>

<style>
  .back {
    font-weight: 700;
    font-size: 13px;
  }
  .header {
    display: flex;
    gap: 32px;
    align-items: center;
    margin: 28px 0 40px;
  }
  .avatar {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
  }
  .name {
    font-size: 30px;
    font-weight: 800;
    color: var(--color-ink);
    margin: 0 0 6px;
  }
  .title {
    font-size: 15px;
    color: var(--color-muted);
    margin-bottom: 14px;
  }
  .social {
    display: flex;
    gap: 16px;
  }
  .social a {
    font-weight: 700;
    font-size: 13px;
  }
  .bio {
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-body);
    margin: 0 0 40px;
    white-space: pre-line;
  }
  .videos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .video-row {
    display: flex;
    gap: 14px;
    color: inherit;
  }
  .thumb {
    width: 130px;
    height: 80px;
    flex-shrink: 0;
    border-radius: 8px;
    object-fit: cover;
    background: oklch(0.93 0.01 260);
  }
  .video-title {
    font-weight: 700;
    font-size: 14px;
    color: var(--color-ink);
    margin-bottom: 4px;
    line-height: 1.3;
  }
  .video-duration {
    font-size: 12px;
    color: var(--color-muted);
  }
  @media (max-width: 600px) {
    .videos-grid {
      grid-template-columns: 1fr;
    }
    .header {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
