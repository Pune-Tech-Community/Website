---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { tagClass, thumbClass, formatDate } from '../../lib/tags';

const now = new Date();
const TOPICS = ['All', 'Azure', 'AI', 'Power Platform', 'M365', '.NET', 'Community'];

const allImportedEvents = await getCollection('events', ({ data }) => !data.draft);

const upcoming = allImportedEvents
  .filter((e) => e.data.date >= now)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())
  .map((e) => ({
    href: `/events/${e.id}`,
    title: e.data.title,
    tag: e.data.tag,
    format: e.data.format,
    date: formatDate(e.data.date),
    image: e.data.image,
    tab: 'upcoming' as const,
  }));

const past = allImportedEvents
  .filter((e) => e.data.date < now)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((e) => ({
    href: e.data.meetupUrl,
    title: e.data.title,
    tag: e.data.tag,
    format: e.data.format,
    date: formatDate(e.data.date),
    image: e.data.image,
    tab: 'past' as const,
  }));

const allEvents = [...upcoming, ...past];
---

<Layout
  title="Events"
  description="Free talks and workshops on Azure, AI, Power Platform and Microsoft 365 — in Pune and online."
>
  <div class="container">
    <h1 class="page-title">Events</h1>
    <p class="page-subtitle">Free talks and workshops on Azure, AI, Power Platform and Microsoft 365 — in Pune and online.</p>

    <div class="controls">
      <div class="tabs">
        <button class="filter-btn" data-tab="upcoming" aria-pressed="true">Upcoming</button>
        <button class="filter-btn" data-tab="past" aria-pressed="false">Past</button>
      </div>
      <input type="search" id="event-search" placeholder="Search events…" aria-label="Search events" />
      <div class="topics">
        {TOPICS.map((t, i) => <button class="filter-btn" data-topic={t} aria-pressed={i === 0}>{t}</button>)}
      </div>
    </div>

    <div class="grid-3" id="event-grid">
      {
        allEvents.map((ev) => (
          <a
            href={ev.href}
            target={ev.tab === 'past' ? '_blank' : undefined}
            rel={ev.tab === 'past' ? 'noopener' : undefined}
            class="card event-card"
            data-tab={ev.tab}
            data-topic={ev.tag}
            data-title={ev.title.toLowerCase()}
            style={ev.tab === 'past' ? 'display:none;' : ''}
          >
            {ev.image ? (
              <img src={ev.image} alt="" class="thumb-img" />
            ) : (
              <div class:list={['thumb', thumbClass(ev.tag)]}>event banner</div>
            )}
            <div class="card-body">
              <div class="badges">
                <span class:list={['badge', tagClass(ev.tag)]}>{ev.tag}</span>
                <span class="badge badge-format">{ev.format}</span>
              </div>
              <div class="event-title">{ev.title}</div>
              <div class="event-date">{ev.date}</div>
              {ev.tab === 'upcoming' ? (
                <span class="btn btn-primary btn-block">RSVP</span>
              ) : (
                <span class="btn btn-outline btn-block">View event</span>
              )}
            </div>
          </a>
        ))
      }
    </div>
    <p id="no-results" hidden>No events match your filters.</p>
  </div>
</Layout>

<script>
  const grid = document.getElementById('event-grid')!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-tab]'));
  const tabButtons = document.querySelectorAll<HTMLButtonElement>('[data-tab].filter-btn');
  const topicButtons = document.querySelectorAll<HTMLButtonElement>('[data-topic].filter-btn');
  const searchInput = document.getElementById('event-search') as HTMLInputElement;
  const noResults = document.getElementById('no-results')!;

  let activeTab = 'upcoming';
  let activeTopic = 'All';

  function applyFilters() {
    const query = searchInput.value.trim().toLowerCase();
    let visibleCount = 0;
    for (const card of cards) {
      const matches =
        card.dataset.tab === activeTab &&
        (activeTopic === 'All' || card.dataset.topic === activeTopic) &&
        (!query || card.dataset.title!.includes(query));
      card.style.display = matches ? '' : 'none';
      if (matches) visibleCount++;
    }
    noResults.hidden = visibleCount > 0;
  }

  tabButtons.forEach((btn) =>
    btn.addEventListener('click', () => {
      activeTab = btn.dataset.tab!;
      tabButtons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
      applyFilters();
    })
  );

  topicButtons.forEach((btn) =>
    btn.addEventListener('click', () => {
      activeTopic = btn.dataset.topic!;
      topicButtons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
      applyFilters();
    })
  );

  searchInput.addEventListener('input', applyFilters);

  applyFilters();
</script>

<style>
  .controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 28px;
  }
  .tabs {
    display: flex;
    gap: 8px;
  }
  .topics {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  #event-search {
    font-family: inherit;
    font-size: 14px;
    padding: 9px 14px;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    min-width: 220px;
  }
  .thumb {
    height: 150px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: ui-monospace, monospace;
    font-size: 11px;
    color: oklch(0.5 0.01 260);
  }
  .thumb-img {
    width: 100%;
    height: 150px;
    object-fit: cover;
  }
  .card-body {
    padding: 20px;
  }
  .badges {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
  }
  .event-card {
    display: block;
    color: inherit;
  }
  .event-title {
    font-weight: 700;
    font-size: 16px;
    color: var(--color-ink);
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .event-date {
    font-size: 13px;
    color: var(--color-muted);
    margin-bottom: 16px;
  }
  #no-results {
    text-align: center;
    color: var(--color-muted);
    padding: 40px 0;
  }
</style>
